# OpenRouter API配置
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# JWT密钥（生产环境请更换为随机字符串）
JWT_SECRET=your-jwt-secret-key-here

# 服务器配置
PORT=3001

# 微信支付配置（生产环境填写真实值）
WECHAT_PAY_MCHID=your-mch-id
WECHAT_PAY_SERIAL=your-serial-number
WECHAT_PAY_APIV3_KEY=your-apiv3-key
WECHAT_PAY_PRIVATE_KEY=your-private-key-path

# 前端URL
FRONTEND_URL=http://localhost:3000

# 邮件服务（可选，不配置则验证码输出到控制台）
# 方案1: Resend (推荐，免费100封/天)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# 方案2: SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password

# Anthropic 直连（可选，配置后启用智能路由）
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# DeepSeek 直连（可选）
# DEEPSEEK_API_KEY=sk-xxxxx
